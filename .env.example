# === Synology ===
SYNOLOGY_HOST=synology
SYNOLOGY_USER=admin
SYNOLOGY_PATH=/volume1/docker/k90

# === Deployment ===

# Lokalny proxy (Zscaler) — usuń lub zostaw puste na Synology
SIGNAL_CLI_EXTRA_ARGS=--http-proxy http://host.docker.internal:9000

# Ścieżka do danych (domyślnie ./data)
# DATA_PATH=./data

# Obraz agenta (Synology / docker compose)
# AGENT_IMAGE=ghcr.io/admroz/k90:latest

# === Garmin ===

GARMIN_EMAIL=twoj@email.com
GARMIN_PASSWORD=twoje_haslo
# GARMIN_END_DATE=2026-03-18

# === Agent ===

# Model LLM do konwersacji (LiteLLM format)
AGENT_MODEL=gpt-4o

# Model LLM do generowania patient summary
SUMMARY_MODEL=gpt-4o

# Ile ostatnich par wiadomości dołączać do kontekstu
HISTORY_MESSAGES=10

# Po ilu dniach auto-odświeżenie patient summary przy starcie
SUMMARY_MAX_AGE_DAYS=7

# Maksymalna liczba tokenów output dla patient summary
SUMMARY_MAX_TOKENS=600

# Klucze API
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here

# Ścieżka do bazy SQLite (opcjonalne, domyślnie /data/k90.db w kontenerze)
# DB_PATH=/data/k90.db

# Strefa czasowa aplikacji
APP_TIMEZONE=Europe/Warsaw

# Signal
# SIGNAL_PHONE_NUMBER=+48...
# SIGNAL_ALLOWED_SENDER=+48...
# SIGNAL_CLI_REST_API_URL=http://signal:8080
