# === Deployment ===

# Lokalny proxy (Zscaler) — usuń lub zostaw puste na Synology
SIGNAL_CLI_EXTRA_ARGS=--http-proxy http://host.docker.internal:9000

# Ścieżka do danych (domyślnie ./data)
# DATA_PATH=./data

# Obraz agenta z GHCR (tylko Synology; lokalnie pomijane, używany build:)
# AGENT_IMAGE=ghcr.io/OWNER/k90:latest

# === Garmin ===

GARMIN_EMAIL=twoj@email.com
GARMIN_PASSWORD=twoje_haslo

# Zakres dat do pobrania (domyślnie od 2022-01-01 do dziś)
GARMIN_START_DATE=2022-01-01
# GARMIN_END_DATE=2026-03-11

# === Agent ===

# Model LLM do konwersacji (LiteLLM format)
# Claude: claude-haiku-4-5-20251001, claude-sonnet-4-6
# Gemini: gemini/gemini-2.0-flash, gemini/gemini-1.5-pro
AGENT_MODEL=claude-haiku-4-5-20251001

# Model LLM do generowania podsumowania pacjenta (preferowany większy model)
SUMMARY_MODEL=claude-sonnet-4-6

# Ile ostatnich wiadomości dołączać do kontekstu
HISTORY_MESSAGES=10

# Po ilu dniach auto-odświeżenie podsumowania pacjenta przy starcie
SUMMARY_MAX_AGE_DAYS=7

# Klucze API
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here

# Ścieżka do bazy SQLite (opcjonalne, domyślnie /data/k90.db w kontenerze)
# DB_PATH=/data/k90.db

# Signal
# SIGNAL_PHONE_NUMBER=+48...       # numer bota Signal
# SIGNAL_ALLOWED_SENDER=+48...     # Twój numer (whitelist)
# SIGNAL_CLI_REST_API_URL=http://signal:8080
